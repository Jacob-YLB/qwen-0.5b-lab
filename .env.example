# ============================================================
# 复制为 .env 后按需修改；.env 已在 .gitignore 里，不会被提交。
# 本项目脚本会读取 BASE_MODEL，其它变量主要给 vLLM / 数据环节用。
# ============================================================

# ---------- 模型 ----------
# 基座模型：Hugging Face 名 或 本地路径
BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# ---------- Hugging Face 下载 ----------
# 国内直连 HF 经常超时/失败，改用镜像站（去掉前导 # 启用）
# HF_ENDPOINT=https://hf-mirror.com
# 把模型缓存放到项目内（默认是 ~/.cache/huggingface），方便清理
# HF_HOME=/home/jacob/qwen-0.5b-lab/.hf_cache

# ---------- GPU ----------
# 多卡时限制只用第 0 张卡
CUDA_VISIBLE_DEVICES=0

# ---------- vLLM 服务（部署环节用）----------
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
